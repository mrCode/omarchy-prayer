#!/usr/bin/env ruby
$LOAD_PATH.unshift File.expand_path('../lib', __dir__)

require 'date'
require 'json'
require 'omarchy_prayer/first_run'
require 'omarchy_prayer/config'
require 'omarchy_prayer/today'
require 'omarchy_prayer/paths'
require 'omarchy_prayer/setup'
require 'fileutils'

def today_cache_fresh?
  data = JSON.parse(File.read(OmarchyPrayer::Paths.today_json))
  data['date'] == Date.today.strftime('%Y-%m-%d')
rescue Errno::ENOENT, JSON::ParserError
  false
end

def ensure_today!
  return if today_cache_fresh?
  schedule = File.expand_path('omarchy-prayer-schedule', __dir__)
  # Send schedule's stdout to stderr so `today` / `next` stdout stays a
  # clean, parseable list — first-run progress still reaches the user.
  ok = system(schedule, out: $stderr)
  return if ok && today_cache_fresh?
  abort <<~MSG.chomp
    omarchy-prayer: could not compute today's times.
      enable the timer:  systemctl --user enable --now omarchy-prayer-schedule.timer
      or refresh now:    omarchy-prayer refresh
  MSG
end

def cmd_today
  ensure_today!
  t = OmarchyPrayer::Today.read
  OmarchyPrayer::Today::ORDER.each { |p| puts format('%-8s %s', p, t.times[p]) }
end

def cmd_next
  ensure_today!
  t = OmarchyPrayer::Today.read
  name, at = t.next_prayer
  puts "#{name} #{at.strftime('%H:%M')}"
end

def cmd_status
  ensure_today!
  t = OmarchyPrayer::Today.read
  line = "date #{t.date}  source #{t.source}  method #{t.method}  city #{t.city}"
  line += "  hijri #{t.hijri}" if t.hijri
  puts line
end

def cmd_refresh
  schedule = File.expand_path('omarchy-prayer-schedule', __dir__)
  exec(schedule)
end

def cmd_relocate(argv)
  require 'omarchy_prayer/relocate'
  OmarchyPrayer::Relocate.run(argv)
  schedule = File.expand_path('omarchy-prayer-schedule', __dir__)
  exec(schedule)
end

def cmd_mute_today
  if File.exist?(OmarchyPrayer::Paths.mute_today)
    File.delete(OmarchyPrayer::Paths.mute_today)
    puts 'mute-today: cleared'
  else
    OmarchyPrayer::Paths.ensure_state_dir
    FileUtils.touch(OmarchyPrayer::Paths.mute_today)
    puts 'mute-today: set (auto-clears at midnight)'
  end
end

def cmd_tui
  require 'omarchy_prayer/tui'
  OmarchyPrayer::FirstRun.ensure_config!
  # Idempotent — no-op fast path when everything is already in place.
  OmarchyPrayer::Setup.run(io: $stderr)
  OmarchyPrayer::TUI.new.run
end

def cmd_setup
  OmarchyPrayer::FirstRun.ensure_config!
  changes = OmarchyPrayer::Setup.run
  if changes.empty?
    puts 'omarchy-prayer: already set up (adhan audio, waybar widget, systemd timer).'
  else
    changes.each { |line| puts "  - #{line}" }
  end
end

def cmd_adhans(argv)
  require 'omarchy_prayer/adhan_manager'
  require 'omarchy_prayer/adhan_catalog'
  sub = argv.shift
  case sub
  when nil, 'list'
    entries = OmarchyPrayer::AdhanManager.list
    col_key = entries.map { |e| e[:key].length }.max
    col_lbl = entries.map { |e| e[:label].length }.max
    entries.each do |e|
      flag = e[:downloaded] ? '●' : '○'
      puts format("  %s  %-#{col_key}s  %-#{col_lbl}s", flag, e[:key], e[:label])
    end
    puts
    puts '  ● = downloaded    ○ = not downloaded'
    puts '  download:  omarchy-prayer adhans download <key>'
    puts '  set:       omarchy-prayer adhans set <key> [--fajr]'
  when 'download'
    key = argv.shift or abort 'usage: omarchy-prayer adhans download <key>'
    OmarchyPrayer::AdhanManager.download(key)
  when 'set'
    key = argv.shift or abort 'usage: omarchy-prayer adhans set <key> [--fajr]'
    fajr = argv.include?('--fajr')
    OmarchyPrayer::AdhanManager.set(key, fajr: fajr)
  when 'current'
    cur = OmarchyPrayer::AdhanManager.current
    puts "adhan       #{cur[:adhan] || '(unset)'}"
    puts "adhan_fajr  #{cur[:adhan_fajr] || '(unset)'}"
  else
    abort "unknown adhans subcommand: #{sub.inspect}"
  end
end

case ARGV[0]
when nil, 'tui'   then cmd_tui
when 'today'      then cmd_today
when 'next'       then cmd_next
when 'status'     then cmd_status
when 'refresh'    then cmd_refresh
when 'relocate'   then cmd_relocate(ARGV[1..] || [])
when 'mute-today' then cmd_mute_today
when 'adhans'     then cmd_adhans(ARGV[1..] || [])
when 'setup'      then cmd_setup
when '-h', '--help', 'help'
  puts <<~USAGE
    usage: omarchy-prayer [command]

    commands:
      tui           open the TUI (default)
      today         print today's prayer times
      next          print next prayer name + time
      status        print source/method/city/hijri line
      refresh       re-run the scheduler
      relocate      update [location] (re-detect via IP, or pass --lat/--lon/--city/--country)
      mute-today    toggle today-only mute flag
      adhans        manage adhan audio library (list|download|set|current)
      setup         download default adhans, patch waybar config, enable timers
  USAGE
else
  warn "unknown subcommand: #{ARGV[0].inspect}"
  exit 1
end
